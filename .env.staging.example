# Copy this to .env.staging and fill in the values.
# Used when running staging integration tests locally: pytest tests/
# In CI, these are injected as GitHub Actions secrets — no file needed.

STAGING_URL=https://auto-tuck-shop-staging.fly.dev

# Must match the TEST_API_KEY secret set in Fly staging
TEST_API_KEY=

# From Meta app dashboard → App Settings → App Secret
META_WHATSAPP_APP_SECRET=
