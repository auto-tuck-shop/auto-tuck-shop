# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://autotuckshop.site

# Database
DATABASE_URL=postgres://user:password@localhost:5432/auto_tuck_shop

# Meta WhatsApp Business Cloud API
META_WHATSAPP_ACCESS_TOKEN=your-access-token-here
META_WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
META_WHATSAPP_VERIFY_TOKEN=your-verify-token
META_WHATSAPP_APP_SECRET=your-app-secret

# Admin notification (receives waitlist approval requests)
ADMIN_PHONE_NUMBER=+263... # Your admin WhatsApp number with country code

# OpenRouter
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=google/gemini-2.5-flash-lite

# Eleven Labs
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# Cloudflare R2 Storage
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
R2_BUCKET_NAME=whatsapp-media
R2_PUBLIC_URL=https://your-r2-public-url.com

# WhatsApp Typing and Read Indicators
ENABLE_WHATSAPP_TYPING=True
ENABLE_WHATSAPP_MARK_AS_READ=True
