{
  "botName": "Auto Tuck Shop",
  "botAvatar": "A",
  "initialMessages": [
    {
      "type": "text",
      "text": "⚠️ *Items Expiring Soon*\n\nThese are getting close:\n\n🥛 Fresh Milk — 6 bottles\nExpires: Thu 30 Jan (3 days)\n\n🍞 Bread — 4 loaves\nExpires: Tomorrow\n\n💭 You can drop the price a bit to move them faster, or I can help you calculate a discount.",
      "buttons": ["Set Discount", "Remind Me Tomorrow"],
      "sent": false,
      "delay": 800
    }
  ],
  "triggers": [
    {
      "match": "set discount",
      "matchType": "button",
      "responses": [
        {
          "type": "text",
          "text": "Set Discount",
          "sent": true,
          "delay": 100
        },
        {
          "type": "card",
          "title": "💸 Suggested Discounts",
          "items": [
            "🥛 Fresh Milk",
            "Normal: R18 → Discount: R14 (22% off)",
            "You still cover your cost",
            "",
            "🍞 Bread",
            "Normal: R14 → Discount: R10 (29% off)",
            "You still cover your cost",
            "",
            "💭 Your assistant will see these new prices automatically"
          ],
          "total": "",
          "buttons": ["Apply These", "Change Amounts"],
          "sent": false,
          "delay": 600
        }
      ]
    },
    {
      "match": "apply these",
      "matchType": "button",
      "responses": [
        {
          "type": "text",
          "text": "Apply These",
          "sent": true,
          "delay": 100
        },
        {
          "type": "text",
          "text": "✅ Discounts applied!\n\nWhen your assistant records sales today, she'll see these new prices automatically. No need to call her.",
          "sent": false,
          "delay": 500
        }
      ]
    },
    {
      "match": "change amounts",
      "matchType": "button",
      "responses": [
        {
          "type": "text",
          "text": "Change Amounts",
          "sent": true,
          "delay": 100
        },
        {
          "type": "text",
          "text": "You can adjust the discount amounts to fit your needs. What would you prefer?",
          "sent": false,
          "delay": 400
        }
      ]
    },
    {
      "match": "remind me tomorrow",
      "matchType": "button",
      "responses": [
        {
          "type": "text",
          "text": "Remind Me Tomorrow",
          "sent": true,
          "delay": 100
        },
        {
          "type": "text",
          "text": "No problem. I'll remind you again tomorrow morning.",
          "sent": false,
          "delay": 400
        }
      ]
    },
    {
      "match": "any",
      "matchType": "sequential",
      "responses": [
        {
          "type": "text",
          "text": "� *Running Low on Fast Sellers*\n\n🧃 Mazoe Orange: 4 left (you sell 7/day)\n🥤 Coke 500ml: 8 left (you sell 5/day)\n📱 Airtime R5: 3 vouchers left\n\n💭 Time to order more before they run out.",
          "buttons": ["Create Order List", "I'll Do It Later"],
          "sent": false,
          "delay": 800
        }
      ]
    },
    {
      "match": "create order list",
      "matchType": "button",
      "responses": [
        {
          "type": "text",
          "text": "Create Order List",
          "sent": true,
          "delay": 100
        },
        {
          "type": "card",
          "title": "📝 Order List — 28 Jan",
          "items": [
            "Mazoe Orange 2L x12 — R180",
            "Coke 500ml x24 — R288",
            "Airtime R5 x20 — R100",
            "",
            "Subtotal: R568",
            "Transport (estimate): R50"
          ],
          "total": "Total: R618",
          "buttons": ["Copy List", "Done"],
          "sent": false,
          "delay": 700
        }
      ]
    },
    {
      "match": "copy list",
      "matchType": "button",
      "responses": [
        {
          "type": "text",
          "text": "Copy List",
          "sent": true,
          "delay": 100
        },
        {
          "type": "text",
          "text": "✓ List copied! You can paste it into WhatsApp or use it as a reminder.",
          "sent": false,
          "delay": 400
        }
      ]
    },
    {
      "match": "done",
      "matchType": "button",
      "responses": [
        {
          "type": "text",
          "text": "Done",
          "sent": true,
          "delay": 100
        },
        {
          "type": "text",
          "text": "Great! Let me know when your order arrives.",
          "sent": false,
          "delay": 400
        }
      ]
    },
    {
      "match": "i'll do it later",
      "matchType": "button",
      "responses": [
        {
          "type": "text",
          "text": "I'll Do It Later",
          "sent": true,
          "delay": 100
        },
        {
          "type": "text",
          "text": "No problem! I'll alert you again if stock gets critically low.",
          "sent": false,
          "delay": 400
        }
      ]
    },
    {
      "match": "price",
      "matchType": "sequential",
      "responses": [
        {
          "type": "text",
          "text": "All good! Your pricing looks healthy right now. I'll let you know if I notice any margin issues.",
          "sent": false,
          "delay": 500
        }
      ]
