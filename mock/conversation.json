{
  "botName": "Auto Tuck Shop",
  "botAvatar": "A",
  "initialMessages": [
    {
      "type": "text",
      "text": "Welcome to Auto Tuck Shop! Your account has been approved.\n\nCompany: Jonah's shop\n\nYou can now send sales messages to track your sales. As an owner, you can also add assistants by sending messages like:\n'add assistant +27821234567'",
      "sent": false,
      "delay": 0
    }
  ],
  "triggers": [
    {
      "match": "sold 2 juices",
      "matchType": "contains",
      "responses": [
        {
          "type": "card",
          "title": "Sale #13",
          "items": [
            "2x Juice @ R20.00"
          ],
          "total": "R40.00",
          "buttons": ["Confirm", "Cancel"],
          "delay": 800
        }
      ]
    },
    {
      "match": "sold 3 chips",
      "matchType": "contains",
      "responses": [
        {
          "type": "card",
          "title": "Sale #14",
          "items": [
            "3x Chips @ R15.00"
          ],
          "total": "R45.00",
          "buttons": ["Confirm", "Cancel"],
          "delay": 800
        }
      ]
    },
    {
      "match": "confirm",
      "matchType": "button",
      "responses": [
        {
          "type": "quoted",
          "quotedTitle": "Auto Tuck Shop",
          "quotedText": "Sale #13 - 2x Juice @ R20...",
          "text": "Confirm",
          "sent": true,
          "delay": 100
        },
        {
          "type": "confirmation",
          "text": "Sale #13 confirmed",
          "sent": false,
          "delay": 600
        }
      ]
    },
    {
      "match": "cancel",
      "matchType": "button",
      "responses": [
        {
          "type": "text",
          "text": "Sale cancelled. No worries!",
          "sent": false,
          "delay": 500
        }
      ]
    },
    {
      "match": "sales today",
      "matchType": "contains",
      "responses": [
        {
          "type": "card",
          "title": "Today's Sales",
          "items": [
            "12 transactions",
            "R580.00 revenue",
            "Top seller: Juice (8 sold)"
          ],
          "total": "R580.00",
          "delay": 800
        }
      ]
    },
    {
      "match": "low stock",
      "matchType": "contains",
      "responses": [
        {
          "type": "text",
          "text": "Low Stock Alert:\n\n• Juice: 3 remaining\n• Chips: 5 remaining\n• Chocolates: 2 remaining",
          "sent": false,
          "delay": 600
        }
      ]
    },
    {
      "match": "help",
      "matchType": "contains",
      "responses": [
        {
          "type": "text",
          "text": "Here's what I can do:\n\nRecord Sales\n\"I sold 2 juices at R20 each\"\n\nView Reports\n\"Show my sales today\"\n\nCheck Stock\n\"What's low stock?\"\n\nEnd of Day\n\"Cash up for today\"",
          "sent": false,
          "delay": 500
        }
      ]
    },
    {
      "match": "cash up",
      "matchType": "contains",
      "responses": [
        {
          "type": "card",
          "title": "Cash Up Summary",
          "items": [
            "Opening float: R200.00",
            "Cash sales: R580.00",
            "Expected in drawer: R780.00"
          ],
          "total": "R780.00",
          "buttons": ["Confirm", "Adjust"],
          "delay": 800
        }
      ]
    }
  ]
}
